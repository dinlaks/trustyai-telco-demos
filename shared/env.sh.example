# env.sh.example — TrustyAI Telco Demo Environment Configuration
#
# Copy this file and source it before running setup scripts:
#   cp shared/env.sh.example shared/env.sh
#   source shared/env.sh
#
# shared/env.sh is gitignored — never commit real values.

# ---------------------------------------------------------------------------
# Demo Namespace
# The namespace where the demo workloads run (TrustyAI, KServe ISVC, MinIO,
# Pushgateway). Created by cluster-admin-setup.sh.
# ---------------------------------------------------------------------------
export NAMESPACE="telco-bias-demo"

# ---------------------------------------------------------------------------
# RHOAI Project and Workbench
# The RHOAI data science project and workbench name where the notebook runs.
# The workbench service account is: system:serviceaccount:<RHOAI_PROJECT>:<WORKBENCH_SA>
# ---------------------------------------------------------------------------
export RHOAI_PROJECT="rhoai-demo"
export WORKBENCH_SA="telco-wb"

# ---------------------------------------------------------------------------
# Model
# Name used for the KServe InferenceService and TrustyAI metric labels.
# ---------------------------------------------------------------------------
export MODEL_NAME="network-slice-model"

# ---------------------------------------------------------------------------
# MinIO
# Internal S3-compatible object storage for model artifacts.
# The route host is set after Cell 1 deploys MinIO — update if it changes
# after a pod restart.
# ---------------------------------------------------------------------------
export MINIO_ENDPOINT="https://minio-s3-${NAMESPACE}.apps.<your-cluster-domain>"
export MINIO_ACCESS_KEY="minio"
export MINIO_SECRET_KEY="minio123"
export MINIO_BUCKET="models"

# ---------------------------------------------------------------------------
# Prometheus Pushgateway
# Internal cluster URL — only reachable from within the cluster (notebook pod).
# ---------------------------------------------------------------------------
export PUSHGATEWAY_URL="http://pushgateway.${NAMESPACE}.svc.cluster.local:9091"

# ---------------------------------------------------------------------------
# TrustyAI
# Internal service URL — KServe agent sends inferences here over TLS.
# ---------------------------------------------------------------------------
export TRUSTYAI_URL="https://trustyai-service.${NAMESPACE}.svc.cluster.local:443"

# ---------------------------------------------------------------------------
# KServe Inference (internal only — no external route in RawDeployment mode)
# Inferences are sent via oc exec into the ISVC pod on port 9081 (KServe agent).
# INFER_URL is not used externally; kept here for reference.
# ---------------------------------------------------------------------------
export INFER_URL="http://localhost:9081/v2/models/${MODEL_NAME}/infer"

# ---------------------------------------------------------------------------
# Grafana Dashboard
# Dashboard ConfigMap is applied to openshift-config-managed.
# UID must match the value in bias-detection/setup/grafana-bias-dashboard.yaml.
# ---------------------------------------------------------------------------
export GRAFANA_DASHBOARD_UID="trustyai-bias-005"
export GRAFANA_NAMESPACE="openshift-config-managed"
